# ReBon Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to GitHub!

# =============================================================================
# AI API KEYS (From your account)
# =============================================================================

# Groq - Fast AI inference (chat, challenges)
GROQ_API_KEY=your-groq-api-key-here

# NVIDIA NIM - Deep analysis (stories, complex reasoning)
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key-here

# Deepgram - Voice transcription
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# Sarvam AI - Multilingual support (10 Indian languages)
SARVAM_API_KEY=your-sarvam-api-key-here

# =============================================================================
# Database (MySQL/TiDB)
# =============================================================================

# TiDB Cloud (free tier) - Get from https://tidbcloud.com
# Or use any MySQL database
DATABASE_URL=mysql://user:password@host:3306/rebon

# =============================================================================
# Authentication
# =============================================================================

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-key-here

# Manus OAuth Configuration
VITE_APP_ID=your-manus-app-id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im/login

# =============================================================================
# Manus Forge APIs (Built-in APIs)
# =============================================================================

BUILT_IN_FORGE_API_URL=https://api.manus.im/forge
BUILT_IN_FORGE_API_KEY=your-forge-api-key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im/forge
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key

# =============================================================================
# Owner Info
# =============================================================================

OWNER_OPEN_ID=your-owner-open-id
OWNER_NAME=Your Name

# =============================================================================
# Optional: Email/OTP Configuration
# =============================================================================

# SMTP (for OTP emails) - Optional for development
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=re@resend.com
# SMTP_PASS=re_1234567890
# SMTP_FROM="ReBon <noreply@rebon.app>"

# =============================================================================
# Production Build
# =============================================================================

# Set to production for optimized builds
NODE_ENV=production
